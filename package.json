{
  "name": "othello3d",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "node --test test/*.test.js",
    "lint": "eslint js/ functions/ test/",
    "lint:fix": "eslint js/ functions/ test/ --fix",
    "format": "prettier --write \"js/**/*.js\" \"functions/**/*.js\" \"test/**/*.js\"",
    "format:check": "prettier --check \"js/**/*.js\" \"functions/**/*.js\" \"test/**/*.js\"",
    "check": "npm run lint && npm run format:check && npm test"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1"
  }
}
